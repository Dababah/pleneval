generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String               @id @default(cuid())
  name           String?
  firstName      String?              @map("first_name")
  lastName       String?              @map("last_name")
  username       String?              @unique
  email          String?              @unique
  emailVerified  DateTime?            @map("email_verified")
  password       String?
  image          String?
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  accounts       Account[]
  events         Event[]
  budgets        FinanceBudget[]
  debts          FinanceDebt[]
  investments    FinanceInvestment[]
  savingGoals    FinanceSavingGoal[]
  transactions   FinanceTransaction[]
  goals          Goal[]
  habits         Habit[]
  journalEntries JournalEntry[]
  notes          Note[]
  sessions       Session[]
  tasks          Task[]
  taskCategories TaskCategory[]
  courses        Course[]
  settings       UserSettings?
  followers      Follows[]            @relation("followers")
  following      Follows[]            @relation("following")
  activities     Activity[]

  @@map("users")
}

model Task {
  id          String    @id @default(cuid())
  title       String    @db.VarChar(500)
  description String?   @db.Text
  priority    String    @default("medium") // low, medium, high
  status      String    @default("todo")   // todo, in_progress, done, cancelled
  category    String?   @default("Lainnya")
  dueDate     DateTime? @map("due_date")
  userId      String    @map("user_id")
  position    Int       @default(0)
  
  completedAt DateTime? @map("completed_at")
  cancelledAt DateTime? @map("cancelled_at")
  
  isArchived     Boolean         @default(false) @map("is_archived")
  archivedAt     DateTime?       @map("archived_at")
  archivedReason ArchivedReason? @map("archived_reason")
  
  subtasks    Subtask[]
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([userId], map: "tasks_user_id_fkey")
  @@map("tasks")
}

model Subtask {
  id          String   @id @default(cuid())
  taskId      String   @map("task_id")
  title       String   @db.VarChar(500)
  isDone      Boolean  @default(false) @map("is_done")
  position    Int      @default(0)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([taskId], map: "subtasks_task_id_fkey")
  @@map("subtasks")
}

enum ArchivedReason {
  completed_expired
  cancelled_expired
  manual
}

model TaskCategory {
  id        String   @id @default(cuid())
  name      String
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, name])
  @@map("task_categories")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  start       DateTime
  end         DateTime
  category    String?  @default("general")
  color       String?
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "events_user_id_fkey")
  @@map("events")
}

model Goal {
  id          String      @id @default(cuid())
  title       String
  description String?     @db.Text
  targetDate  DateTime?   @map("target_date")
  progress    Int         @default(0)
  userId      String      @map("user_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones  Milestone[]

  @@index([userId], map: "goals_user_id_fkey")
  @@map("goals")
}

model Milestone {
  id          String   @id @default(cuid())
  title       String
  isCompleted Boolean  @default(false) @map("is_completed")
  goalId      String   @map("goal_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId], map: "milestones_goal_id_fkey")
  @@map("milestones")
}

model Habit {
  id           String     @id @default(cuid())
  title        String
  description  String?    @db.Text
  frequency    String     @default("daily")
  scheduleDays String?    @map("schedule_days") @db.Text
  icon         String?    @default("⚡")
  currentStreak Int       @default(0) @map("current_streak")
  userId       String     @map("user_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  items        HabitItem[]
  logs         HabitLog[]
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "habits_user_id_fkey")
  @@map("habits")
}

model HabitItem {
  id        String   @id @default(cuid())
  title     String
  habitId   String   @map("habit_id")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@index([habitId], map: "habit_items_habit_id_fkey")
  @@map("habit_items")
}

model HabitLog {
  id          String   @id @default(cuid())
  habitId     String   @map("habit_id")
  habitItemId String?  @map("habit_item_id")
  date        DateTime @default(now())
  isCompleted Boolean  @default(true) @map("is_completed")
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@index([habitId], map: "habit_logs_habit_id_fkey")
  @@unique([habitId, habitItemId, date])
  @@map("habit_logs")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String?  @db.Text
  category  String?
  color       String?
  colSpan     Int      @default(1) @map("col_span")
  rowSpan     Int      @default(1) @map("row_span")
  positionX   Int      @default(0) @map("pos_x")
  positionY   Int      @default(0) @map("pos_y")
  isPinned  Boolean  @default(false) @map("is_pinned")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "notes_user_id_fkey")
  @@map("notes")
}

model JournalEntry {
  id        String   @id @default(cuid())
  content   String   @db.Text
  mood      String?
  date      DateTime @default(now())
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("journal_entries")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "accounts_user_id_fkey")
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_user_id_fkey")
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordRecoveryToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email, token])
  @@map("password_recovery_tokens")
}

model FinanceTransaction {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  type      String
  category  String
  date      DateTime @default(now())
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "finance_transactions_user_id_fkey")
  @@map("finance_transactions")
}

model FinanceBudget {
  id        String   @id @default(cuid())
  name      String
  budget    Float
  icon      String   @default("Wallet")
  color     String   @default("#18181b")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "finance_budgets_user_id_fkey")
  @@map("finance_budgets")
}

model FinanceSavingGoal {
  id            String                 @id @default(cuid())
  name          String
  targetAmount  Float                  @map("target_amount")
  currentAmount Float                  @default(0) @map("current_amount")
  icon          String                 @default("Target")
  color         String                 @default("#18181b")
  userId        String                 @map("user_id")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  deposits      FinanceSavingDeposit[]
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "finance_saving_goals_user_id_fkey")
  @@map("finance_saving_goals")
}

model FinanceSavingDeposit {
  id           String            @id @default(cuid())
  amount       Float
  date         DateTime          @default(now())
  savingGoalId String            @map("saving_goal_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  savingGoal   FinanceSavingGoal @relation(fields: [savingGoalId], references: [id], onDelete: Cascade)

  @@index([savingGoalId], map: "finance_saving_deposits_saving_goal_id_fkey")
  @@map("finance_saving_deposits")
}

model FinanceDebt {
  id             String               @id @default(cuid())
  name           String
  totalDebt      Float                @map("total_debt")
  paidAmount     Float                @default(0) @map("paid_amount")
  monthlyPayment Float                @map("monthly_payment")
  dueDayOfMonth  Int                  @map("due_day_of_month")
  startDate      DateTime             @default(now()) @map("start_date")
  status         String               @default("aktif")
  userId         String               @map("user_id")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  payments       FinanceDebtPayment[]
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "finance_debts_user_id_fkey")
  @@map("finance_debts")
}

model FinanceDebtPayment {
  id        String      @id @default(cuid())
  amount    Float
  date      DateTime    @default(now())
  debtId    String      @map("debt_id")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  debt      FinanceDebt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId], map: "finance_debt_payments_debt_id_fkey")
  @@map("finance_debt_payments")
}

model FinanceInvestment {
  id            String   @id @default(cuid())
  name          String
  symbol        String?
  type          String
  initialAmount Float    @map("initial_amount")
  currentValue  Float    @map("current_value")
  lots          Float?
  buyDate       DateTime @default(now()) @map("buy_date")
  userId        String   @map("user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "finance_investments_user_id_fkey")
  @@map("finance_investments")
}

model UserSettings {
  id                        String   @id @default(cuid())
  userId                    String   @unique @map("user_id")
  aiProvider                String?  @map("ai_provider")
  aiModel                   String?  @map("ai_model")
  aiApiKeyEncrypted         String?  @map("ai_api_key_encrypted") @db.Text
  telegramBotTokenEncrypted String?  @map("telegram_bot_token_encrypted") @db.Text
  telegramChatId            String?  @map("telegram_chat_id")
  notifMorningSummary       Boolean  @default(false) @map("notif_morning_summary")
  notifStockDropPct         Float    @default(5) @map("notif_stock_drop_pct")
  notifStockRisePct         Float    @default(10) @map("notif_stock_rise_pct")
  notifDebtReminderDays     Int      @default(3) @map("notif_debt_reminder_days")
  notifBudgetThresholdPct   Int      @default(80) @map("notif_budget_threshold_pct")
  notifSavingReminder       Boolean  @default(false) @map("notif_saving_reminder")
  notifTelegramAiChat       Boolean  @default(false) @map("notif_telegram_ai_chat")
  customAiEndpoint          String?  @map("custom_ai_endpoint") @db.Text
  customAiHeaderName        String?  @map("custom_ai_header_name")
  customAiHeaderPrefix      String?  @map("custom_ai_header_prefix")
  customAiBodyTemplate      String?  @map("custom_ai_body_template") @db.Text
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Course {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  day        String   // "Senin", "Selasa", etc.
  startTime  String   @map("start_time") // "HH:mm"
  endTime    String   @map("end_time")   // "HH:mm"
  courseCode String   @map("course_code")
  courseName String   @map("course_name")
  className  String?  @map("class_name")
  lecturer   String?
  room       String?
  priority   String    @default("medium") // low, medium, high
  color      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "courses_user_id_fkey")
  @@map("courses")
}

model Follows {
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower    User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId], map: "follows_following_id_fkey")
  @@map("follows")
}

model Activity {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        String   // e.g. "MILESTONE_REACHED"
  referenceId String?  @map("reference_id") // ID to habit/goal
  metadata    String?  @db.Text // JSON data e.g. {"milestone": 30}
  createdAt   DateTime @default(now()) @map("created_at")

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "activities_user_id_fkey")
  @@map("activities")
}
